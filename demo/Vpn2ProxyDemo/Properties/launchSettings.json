{
  "profiles": {
    "proxy-server sstp public-vpn-226.opengw.net": {
      "commandName": "Project",
      "commandLineArgs": "proxy-server --vpn sstp://vpn:vpn@public-vpn-226.opengw.net"
    },
    "proxy-server l2tp public-vpn-226.opengw.net": {
      "commandName": "Project",
      "commandLineArgs": "proxy-server --vpn l2tp://vpn:vpn@public-vpn-226.opengw.net"
    },
    "proxy-server l2tp as LAN proxy (0.0.0.0:18080)": {
      "commandName": "Project",
      "commandLineArgs": "proxy-server --vpn l2tp://vpn:vpn@public-vpn-226.opengw.net --proxy-host 0.0.0.0 --proxy-port 18080"
    },
    "http-request sstp checkip (GET rồi thoát)": {
      "commandName": "Project",
      "commandLineArgs": "http-request --vpn sstp://vpn:vpn@public-vpn-226.opengw.net --url https://checkip.amazonaws.com/"
    },
    "http-request l2tp checkip (GET rồi thoát)": {
      "commandName": "Project",
      "commandLineArgs": "http-request --vpn l2tp://vpn:vpn@public-vpn-226.opengw.net --url https://checkip.amazonaws.com/"
    },
    "dns sstp resolve example.com (VPN-assigned DNS)": {
      "commandName": "Project",
      "commandLineArgs": "dns --vpn sstp://vpn:vpn@public-vpn-226.opengw.net --resolve example.com"
    },
    "dns l2tp resolve github.com (via 8.8.8.8)": {
      "commandName": "Project",
      "commandLineArgs": "dns --vpn l2tp://vpn:vpn@public-vpn-226.opengw.net --resolve github.com --dns-server 8.8.8.8"
    },
    "help": {
      "commandName": "Project",
      "commandLineArgs": "--help"
    }
  }
}
